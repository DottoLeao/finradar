# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
__pycache__/
*.py[cod]
.Python

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example committed
.env
.env.*
!.env.example

# supabase local
/supabase/.branches
/supabase/.temp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts: dataset/embedding cache for offline model training (not app source)
/scripts/.cache/

.vercel
